# ============================================================================
#  nano-claw / Space Channel voice console — ENVIRONMENT TEMPLATE
# ============================================================================
#
#  ┌──────────────────────────────────────────────────────────────────────┐
#  │  THIS IS A TEMPLATE. It contains FAKE placeholder values.              │
#  │                                                                        │
#  │  Setup:   cp .env.example .env    then fill in your REAL values.       │
#  │                                                                        │
#  │  NEVER commit .env — it holds live secrets and is gitignored.          │
#  │  NEVER put a real key in THIS file (.env.example is committed).        │
#  │                                                                        │
#  │  FOR AI AGENTS: do not paste real credentials here. Real values go     │
#  │  only in .env (gitignored). Leave every value below as a placeholder.  │
#  │  If a real secret ever lands in a committed file, treat it as leaked   │
#  │  and rotate it at the provider.                                        │
#  └──────────────────────────────────────────────────────────────────────┘

# ── LLM providers ───────────────────────────────────────────────────────────
# At minimum you need ANTHROPIC_API_KEY (the default conversation + scheduler
# model is Claude Haiku). The others enable extra models in the dropdowns; omit
# any you don't use — the app degrades gracefully (that provider's models just
# won't appear).
ANTHROPIC_API_KEY=sk-ant-REPLACE-WITH-YOUR-ANTHROPIC-KEY
GEMINI_API_KEY=REPLACE-WITH-YOUR-GEMINI-KEY
XAI_API_KEY=xai-REPLACE-WITH-YOUR-XAI-KEY
DEEPSEEK_API_KEY=sk-REPLACE-WITH-YOUR-DEEPSEEK-KEY
GROQ_API_KEY=gsk_REPLACE-WITH-YOUR-GROQ-KEY
OPENROUTER_API_KEY=sk-or-REPLACE-WITH-YOUR-OPENROUTER-KEY

# Scheduler (goal-region supervisor) model. Default is Claude Haiku 4.5.
# Examples: claude-haiku-4-5 | deepseek/deepseek-v4-flash | groq/openai/gpt-oss-20b
SCHED_EVAL_MODEL=claude-haiku-4-5

# ── Phone line (Telnyx) — optional; only if you run the phone node ───────────
NANO_CLAW_PHONE=0                          # 1 to enable the Telnyx phone gateway
TELNYX_API_KEY=KEY-REPLACE-WITH-YOUR-TELNYX-KEY
NANO_CLAW_PHONE_WEBHOOK_BASE=https://your-tunnel-host.example.com
NANO_CLAW_PHONE_TOKEN=REPLACE-WITH-A-RANDOM-WEBHOOK-SHARED-SECRET
NANO_CLAW_PHONE_CODEC=l16                  # l16 (HD) | pcmu (8kHz)
NANO_CLAW_PHONE_VAD=energy                 # energy | silero
NANO_CLAW_PHONE_STT_SIZE=base              # tiny | base | small | medium
NANO_CLAW_PHONE_VOICE=af_heart
NANO_CLAW_PHONE_BARGE_IN=1
NANO_CLAW_PHONE_DYNAMIC_ENDPOINT=1

# ── Google sign-in — optional; only if you enable per-user history ───────────
# The Client ID is PUBLIC (it ships in the page) — no client secret is used.
# Create it in Google Cloud Console → Credentials → OAuth client ID (Web app);
# add http://localhost:9090 and your tunnel host as Authorized JS origins.
NANO_CLAW_GOOGLE_CLIENT_ID=REPLACE-WITH-YOUR-CLIENT-ID.apps.googleusercontent.com
NANO_CLAW_AUTH=optional                    # optional | off  (no login button when off)
NANO_CLAW_PUBLIC_HTTPS=0                    # 1 when served over HTTPS (tunnel) so the
                                           # session cookie gets the Secure flag

# ── Console flags ────────────────────────────────────────────────────────────
NANO_CLAW_VOICE_FLOW=scheduler             # boot-default browser flow
NANO_CLAW_BARGE_IN=1                       # expose control; per-browser preference defaults off
NANO_CLAW_MEMORY_DIR=/app/data/memory      # conversation + analysis sidecars on persistent volume
NANO_CLAW_SENTENCE_GAP_MS=240              # silence appended after . ! ? (0-1000 ms)
NANO_CLAW_SPEECH_PREPARATION=1             # prepared natural speech; 0 is the raw A/B rollback
NANO_CLAW_SPEECH_MAX_WORDS=18              # semantic target; never forces arbitrary word cuts
NANO_CLAW_SPEECH_MAX_CHUNK_MS=2500         # estimated maximum prepared chunk duration
NANO_CLAW_PHONE_SPEECH_PREPARATION=1       # use the same compiler on Telnyx calls
NANO_CLAW_DISABLE_TOOLS=0
NANO_CLAW_ANALYSIS_STYLE=topic_map            # topic_map | principle_graph (experimental)
