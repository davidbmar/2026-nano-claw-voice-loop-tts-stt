# M3 (primary phone node) — non-secret settings snapshot.
# Recovery: merge into the node's .env (which also needs the secrets:
# ANTHROPIC_API_KEY, TELNYX_API_KEY, NANO_CLAW_PHONE_TOKEN).
# The M3 runs the premium profile: Kokoro British male + Whisper medium.
NANO_CLAW_BARGE_IN=1
NANO_CLAW_DISABLE_TOOLS=1
NANO_CLAW_PHONE=1
NANO_CLAW_PHONE_WEBHOOK_BASE=https://nano.chattychapters.com
NANO_CLAW_PHONE_BARGE_IN=1
NANO_CLAW_PHONE_VOICE=bm_george
NANO_CLAW_PHONE_STT_SIZE=medium
