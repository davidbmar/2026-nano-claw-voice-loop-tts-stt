# M1 (failover phone node) — non-secret settings snapshot.
# Recovery: merge into the node's .env (plus the same secrets as the M3).
# Lightweight profile: Kokoro/MPS segfaults and runs ~13s/sentence on this
# machine — keep a Piper voice here, never a Kokoro one.
NANO_CLAW_BARGE_IN=1
NANO_CLAW_DISABLE_TOOLS=1
NANO_CLAW_PHONE=1
NANO_CLAW_PHONE_WEBHOOK_BASE=https://nano-m1.chattychapters.com
NANO_CLAW_PHONE_BARGE_IN=1
NANO_CLAW_PHONE_VOICE=en_US-lessac-medium
NANO_CLAW_PHONE_STT_SIZE=small
